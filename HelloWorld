function centerTextPlugin(cid, getText){
  return {id:'ctp_'+cid, afterDraw(chart){
    if(chart.canvas.id!==cid) return;
    const{ctx,chartArea}=chart; if(!chartArea) return;
    const{left,top,right,bottom}=chartArea;
    const cx=(left+right)/2, cy=(top+bottom)/2;
    ctx.save();
    ctx.textAlign='center'; ctx.textBaseline='middle';

    if(cid==='c3_est'){
      const pl=clampEl(document.querySelector('.t3pl[data-idx="0"]'));
      const ac=clampEl(document.querySelector('.t3ac[data-idx="0"]'));
      ctx.font="700 15px 'Outfit'"; ctx.fillStyle='#0b1f45';
      ctx.fillText(`${ac}`, cx, cy-14);
      ctx.strokeStyle='#d0d7e6'; ctx.lineWidth=1;
      ctx.beginPath(); ctx.moveTo(cx-18, cy-2); ctx.lineTo(cx+18, cy-2); ctx.stroke();
      ctx.font="600 11px 'Outfit'"; ctx.fillStyle='#6b7280';
      ctx.fillText(`of ${pl}`, cx, cy+12);
      ctx.font="500 10px 'Outfit'"; ctx.fillStyle='#9ca3af';
      ctx.fillText('Actual / Planned', cx, cy+26);
    } else {
      ctx.font="700 14px 'Outfit'"; ctx.fillStyle='#0b1f45';
      const t=getText(); const lines=String(t).split('\n');
      lines.forEach((ln,i)=>ctx.fillText(ln,cx,cy+(i-(lines.length-1)/2)*16));
    }
    ctx.restore();
  }};
}

